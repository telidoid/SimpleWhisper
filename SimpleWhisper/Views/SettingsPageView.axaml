<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimpleWhisper.ViewModels"
             xmlns:views="using:SimpleWhisper.Views"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:res="clr-namespace:SimpleWhisper.Resources"
             x:Class="SimpleWhisper.Views.SettingsPageView"
             x:DataType="vm:SettingsPageViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="28" Margin="24">

            <!-- Theme -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsTheme}" FontWeight="SemiBold" FontSize="14" />
                <ComboBox ItemsSource="{Binding AvailableThemes}"
                          SelectedItem="{Binding SelectedTheme}"
                          MinWidth="200" />
            </StackPanel>

            <!-- General -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsGeneral}" FontWeight="SemiBold" FontSize="14" />
                <CheckBox Content="{x:Static res:Strings.SettingsMinimizeToTray}"
                          IsChecked="{Binding MinimizeToTray}" />
                <TextBlock Text="{x:Static res:Strings.SettingsMinimizeToTrayHelp}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
                <CheckBox Content="{x:Static res:Strings.SettingsAutoStart}"
                          IsChecked="{Binding AutoStart}"
                          Margin="0,8,0,0" />
                <TextBlock Text="{x:Static res:Strings.SettingsAutoStartHelp}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
            </StackPanel>

            <!-- Language -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsLanguage}" FontWeight="SemiBold" FontSize="14" />
                <ComboBox ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          MinWidth="200" />
                <StackPanel Orientation="Horizontal" Spacing="12"
                            IsVisible="{Binding NeedsLanguageRestart}">
                    <TextBlock Text="{x:Static res:Strings.SettingsLanguageHelp}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
                    <Button Content="{x:Static res:Strings.SettingsRestartNow}"
                            Command="{Binding RestartAppCommand}"
                            Padding="12,4" />
                </StackPanel>
            </StackPanel>

            <!-- Microphone -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsMicrophone}" FontWeight="SemiBold" FontSize="14" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ComboBox ItemsSource="{Binding InputDevices}"
                              SelectedItem="{Binding SelectedInputDevice}"
                              MinWidth="300" />
                    <Button Command="{Binding RefreshInputDevicesCommand}"
                            Padding="6,4"
                            VerticalAlignment="Center"
                            ToolTip.Tip="{x:Static res:Strings.SettingsRefreshDeviceList}">
                        <icons:MaterialIcon Kind="Refresh" Width="16" Height="16" />
                    </Button>
                </StackPanel>
                <TextBlock Text="{x:Static res:Strings.SettingsMicrophoneHelp}"
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
            </StackPanel>

            <!-- Recording Mode -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsRecordingMode}" FontWeight="SemiBold" FontSize="14" />
                <RadioButton Content="{x:Static res:Strings.SettingsRecordingModeHold}"
                             IsChecked="{Binding IsToggleMode, Converter={x:Static BoolConverters.Not}}" />
                <RadioButton Content="{x:Static res:Strings.SettingsRecordingModeToggle}"
                             IsChecked="{Binding IsToggleMode}" />
            </StackPanel>

            <!-- Performance -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsPerformance}" FontWeight="SemiBold" FontSize="14" />
                <CheckBox Content="{Binding GpuAccelerationLabel}"
                          IsChecked="{Binding UseHardwareAcceleration}"
                          IsEnabled="{Binding IsGpuAvailable}" />
                <StackPanel Orientation="Horizontal" Spacing="12"
                            IsVisible="{Binding NeedsRestart}">
                    <TextBlock Text="{x:Static res:Strings.SettingsRestartRequired}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
                    <Button Content="{x:Static res:Strings.SettingsRestartNow}"
                            Command="{Binding RestartAppCommand}"
                            Padding="12,4" />
                </StackPanel>
            </StackPanel>

            <!-- Clipboard -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsClipboard}" FontWeight="SemiBold" FontSize="14" />
                <CheckBox Content="{x:Static res:Strings.SettingsCopyToClipboard}"
                          IsChecked="{Binding CopyToClipboard}"
                          IsEnabled="{Binding !PasteIntoFocusedWindow}" />
                <CheckBox Content="{x:Static res:Strings.SettingsPasteIntoWindow}"
                          IsChecked="{Binding PasteIntoFocusedWindow}"
                          IsEnabled="{Binding IsPasteAvailable}"
                          Margin="24,0,0,0"
                          ToolTip.Tip="{x:Static res:Strings.SettingsPasteWaylandTooltip}"
                          ToolTip.ShowDelay="300"
                          ToolTip.ShowOnDisabled="True" />
            </StackPanel>

            <!-- Notifications -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsNotifications}" FontWeight="SemiBold" FontSize="14" />
                <CheckBox Content="{x:Static res:Strings.SettingsShowNotification}"
                          IsChecked="{Binding ShowNotification}" />
            </StackPanel>

            <!-- Hotkey -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsGlobalHotkey}" FontWeight="SemiBold" FontSize="14" />
                <views:HotkeyRecorderButton HotkeyText="{Binding HotkeyText}"
                                           IsVisible="{Binding IsHotkeyEditable}" />
                <TextBlock TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                           IsVisible="{Binding IsHotkeyEditable, Converter={x:Static BoolConverters.Not}}"
                           Text="{x:Static res:Strings.SettingsWaylandHotkeyHelp}" />
                <Button Content="{x:Static res:Strings.SettingsOpenSystemShortcuts}"
                        Command="{Binding OpenSystemShortcutsCommand}"
                        HorizontalAlignment="Left"
                        IsVisible="{Binding IsHotkeyEditable, Converter={x:Static BoolConverters.Not}}" />
            </StackPanel>

            <!-- Models Directory -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsModelsDirectory}" FontWeight="SemiBold" FontSize="14" />
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding ModelsDirectory}"
                             FontSize="12"
                             FontFamily="Monospace"
                             VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Command="{Binding BrowseModelsDirectoryCommand}"
                            Content="{x:Static res:Strings.SettingsBrowse}"
                            Margin="6,0,0,0"
                            Padding="10,4"
                            VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            Command="{Binding OpenModelsDirectoryCommand}"
                            Margin="6,0,0,0"
                            Padding="6,4"
                            VerticalAlignment="Center"
                            ToolTip.Tip="{x:Static res:Strings.SettingsOpenInFileManager}">
                        <icons:MaterialIcon Kind="FolderOpen" Width="16" Height="16" />
                    </Button>
                </Grid>
            </StackPanel>

            <!-- System Info -->
            <StackPanel Spacing="8">
                <TextBlock Text="{x:Static res:Strings.SettingsSystemInfo}" FontWeight="SemiBold" FontSize="14" />
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static res:Strings.SettingsOS}"
                               Margin="0,0,16,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding OsDescription}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static res:Strings.SettingsDE}"
                               Margin="0,6,16,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DesktopEnvironment}" Margin="0,6,0,0" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static res:Strings.SettingsDisplayServer}"
                               Margin="0,6,16,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DisplayServer}" Margin="0,6,0,0" />
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
