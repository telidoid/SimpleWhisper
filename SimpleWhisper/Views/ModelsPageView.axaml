<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimpleWhisper.ViewModels"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:res="clr-namespace:SimpleWhisper.Resources"
             x:Class="SimpleWhisper.Views.ModelsPageView"
             x:DataType="vm:ModelsPageViewModel">

    <UserControl.Styles>
        <Style Selector="Border.model-row">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="16">

        <!-- In use panel -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <icons:MaterialIcon Kind="CheckCircle"
                                    Width="18" Height="18"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource SystemAccentColor}" />
                <TextBlock Text="{x:Static res:Strings.ModelsInUseLabel}"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Opacity="0.6" />
                <TextBlock Text="{Binding SelectedModelName}"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="Medium" />
            </StackPanel>
        </Border>

        <!-- No-internet banner -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding !IsNetworkAvailable}"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <icons:MaterialIcon Kind="WifiOff"
                                    Width="18" Height="18"
                                    VerticalAlignment="Center" />
                <TextBlock Text="{x:Static res:Strings.ModelsNoInternet}"
                           VerticalAlignment="Center"
                           FontSize="13" />
            </StackPanel>
        </Border>

        <!-- Loading indicator -->
        <StackPanel DockPanel.Dock="Top"
                    IsVisible="{Binding IsLoading}"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,0,0,12">
            <ProgressBar IsIndeterminate="True"
                         Width="120"
                         Height="4"
                         VerticalAlignment="Center" />
            <TextBlock Text="{x:Static res:Strings.ModelsFetching}"
                       FontSize="13"
                       Opacity="0.6"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Search bar with downloaded filter and refresh button -->
        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="*,Auto,Auto"
              Margin="0,0,0,8">
            <TextBox Grid.Column="0"
                     Text="{Binding SearchQuery}"
                     PlaceholderText="{x:Static res:Strings.ModelsSearchWatermark}"
                     FontSize="13" />
            <ToggleButton Grid.Column="1"
                          IsChecked="{Binding ShowDownloadedOnly}"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="6,4"
                          Margin="4,0,0,0"
                          VerticalAlignment="Center"
                          ToolTip.Tip="{x:Static res:Strings.ModelsShowDownloadedOnly}">
                <icons:MaterialIcon Kind="Download"
                                    Width="16" Height="16" />
            </ToggleButton>
            <Button Grid.Column="2"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding !IsLoading}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip.Tip="{x:Static res:Strings.ModelsRefreshList}">
                <icons:MaterialIcon Kind="Refresh"
                                    Width="18" Height="18" />
            </Button>
        </Grid>

        <!-- Model list -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Models}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:ModelItemViewModel">
                        <Border Classes="model-row">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto">

                                <!-- Name + size -->
                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Spacing="2">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="Medium" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding DisplaySize}"
                                                   FontSize="12"
                                                   Opacity="0.6" />
                                        <TextBlock Text="{Binding Language}"
                                                   FontSize="12"
                                                   Opacity="0.6" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Download progress + cancel (while downloading) -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsDownloading}">
                                    <ProgressBar Value="{Binding DownloadProgress}"
                                                 Maximum="1"
                                                 Width="100"
                                                 Height="4"
                                                 VerticalAlignment="Center" />
                                    <Button Command="{Binding CancelDownloadCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="2"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="{x:Static res:Strings.ModelsCancelDownload}">
                                        <icons:MaterialIcon Kind="Close"
                                                            Width="14" Height="14" />
                                    </Button>
                                </StackPanel>

                                <!-- "In use" badge when selected -->
                                <Border Grid.Column="2"
                                        IsVisible="{Binding IsSelected}"
                                        Background="{DynamicResource SystemAccentColor}"
                                        CornerRadius="4"
                                        Padding="8,3"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static res:Strings.ModelsInUseBadge}"
                                               FontSize="11"
                                               Foreground="White"
                                               FontWeight="Medium" />
                                </Border>

                                <!-- "Use" button when downloaded but not selected -->
                                <Button Grid.Column="2"
                                        Command="{Binding SelectCommand}"
                                        Background="Transparent"
                                        Padding="8,3"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{x:Static res:Strings.ModelsUseThisModel}">
                                    <Button.IsVisible>
                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                            <Binding Path="IsDownloaded" />
                                            <Binding Path="!IsSelected" />
                                        </MultiBinding>
                                    </Button.IsVisible>
                                    <TextBlock Text="{x:Static res:Strings.ModelsUseButton}"
                                               FontSize="11" />
                                </Button>

                                <!-- Actions when downloaded: checkmark + delete -->
                                <StackPanel Grid.Column="3"
                                            Orientation="Horizontal"
                                            Spacing="2"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsDownloaded}">
                                    <icons:MaterialIcon Kind="Check"
                                                        Width="22" Height="22"
                                                        Foreground="Green"
                                                        VerticalAlignment="Center" />
                                    <Button Command="{Binding DeleteCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="{x:Static res:Strings.ModelsRemoveModel}">
                                        <icons:MaterialIcon Kind="Delete"
                                                            Width="18" Height="18"
                                                            Opacity="0.5" />
                                    </Button>
                                </StackPanel>

                                <!-- Download button when not downloaded -->
                                <Button Grid.Column="3"
                                        Command="{Binding DownloadCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{x:Static res:Strings.ModelsDownloadModel}"
                                        IsVisible="{Binding !IsDownloaded}">
                                    <icons:MaterialIcon Kind="Download"
                                                        Width="22" Height="22" />
                                </Button>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
