<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimpleWhisper.ViewModels"
             xmlns:res="clr-namespace:SimpleWhisper.Resources"
             x:Class="SimpleWhisper.Views.MainPageView"
             x:DataType="vm:MainPageViewModel">

    <DockPanel Margin="16">
        <!-- Status bar at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="4" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.7" />
            <ProgressBar Value="{Binding DownloadProgress}"
                         Maximum="100"
                         IsVisible="{Binding IsDownloadingModel}"
                         Height="4" />
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="8" Margin="0,8">
            <Button Command="{Binding ToggleRecordingCommand}"
                    Padding="24,12"
                    Content="{Binding RecordButtonText}" />
            <Button Command="{Binding ClearTextCommand}"
                    Padding="12,12"
                    Content="{x:Static res:Strings.ClearTextButton}" />
        </StackPanel>

        <!-- Transcribed text area fills remaining space -->
        <TextBox Text="{Binding TranscribedText, Mode=TwoWay}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 PlaceholderText="{x:Static res:Strings.TranscribedTextWatermark}" />
    </DockPanel>
</UserControl>
