<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SimpleWhisper.ViewModels"
             xmlns:views="using:SimpleWhisper.Views"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="SimpleWhisper.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <DataTemplate DataType="vm:MainPageViewModel">
            <views:MainPageView />
        </DataTemplate>
        <DataTemplate DataType="vm:ModelsPageViewModel">
            <views:ModelsPageView />
        </DataTemplate>
        <DataTemplate DataType="vm:SettingsPageViewModel">
            <views:SettingsPageView />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <icons:MaterialIconStyles />
        <StyleInclude Source="/Styles/AppStyles.axaml" />
    </Application.Styles>
</Application>
